{
  "name": "@continuum/gemini-adapter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:gemini-transport": "cross-env CONTINUUM_REAL_GEMINI_TEST=1 vitest run tests/smoke-transport.test.ts",
    "test:gemini-success": "cross-env CONTINUUM_REAL_GEMINI_SUCCESS_TEST=1 vitest run tests/smoke-success.test.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@continuum/shared": "workspace:*",
    "execa": "^9.5.2",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "rimraf": "^6.0.1",
    "vitest": "^3.2.4"
  }
}
