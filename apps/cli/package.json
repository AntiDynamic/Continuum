{
  "name": "@continuum/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "continuum": "./dist/main.js"
  },
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src",
    "clean": "rimraf dist",
    "start": "node dist/main.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@continuum/agent-core": "workspace:*",
    "@continuum/database": "workspace:*",
    "@continuum/evaluator": "workspace:*",
    "@continuum/gemini-adapter": "workspace:*",
    "@continuum/git-analyzer": "workspace:*",
    "@continuum/mcp-server": "workspace:*",
    "@continuum/repository-indexer": "workspace:*",
    "@continuum/shared": "workspace:*",
    "commander": "^13.1.0",
    "execa": "^9.5.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "rimraf": "^6.0.1",
    "vitest": "^3.2.4"
  }
}
